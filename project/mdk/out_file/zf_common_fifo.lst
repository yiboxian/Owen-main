  547          fifo_state_enum fifo_init (fifo_struct *fifo, fifo_data_type_enum type, void *buffer_addr, uint32 siz)
  548          {
  549   1          zf_assert(NULL != fifo);
  550   1          do
  551   1          {
  552   2              fifo->buffer    = buffer_addr;
  553   2              fifo->execution = FIFO_IDLE;
  554   2              fifo->type      = type;
  555   2              fifo->head      = 0;
  556   2              fifo->end       = 0;
  557   2              fifo->siz      = siz;
  558   2              fifo->max       = siz;
  559   2          }while(0);
  560   1          return FIFO_SUCCESS;
  561   1      }


