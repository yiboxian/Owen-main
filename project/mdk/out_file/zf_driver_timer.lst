   68          uint8 timer_funciton_check (timer_index_enum index, timer_function_enum mode)
   69          {
   70   1          uint8 return_state = 1;
   71   1          if(TIMER_FUNCTION_INIT == timer_function_state[index])
   72   1          {
   73   2              timer_function_state[index] = mode;
   74   2          }
   75   1          else if(timer_function_state[index] == mode)
   76   1          {
   77   2              return_state = 1;
   78   2          }
   79   1          else
   80   1          {
   81   2              return_state = 0;
   82   2          }
   83   1          return return_state;
