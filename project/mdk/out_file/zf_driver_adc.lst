  127          void adc_init(adc_channel_enum ch, adc_resolution_enum resolution)
  128          {
  129   1          gpio_init(ch & 0xFF, GPI, 1, GPI_ANALOG);
  130   1      
  131   1          if((ch >> 12) == 0)
  132   1          {
  133   2      
  134   2              ADC_CONTR &= (0xF0);                            // ЧхГ§ADC_CHS[3:0] ЃК ADC ФЃФтЭЈЕРбЁдёЮЛ
  135   2              ADC_CONTR |= (ch >> 8) & 0xF;
  136   2              
  137   2              ADCCFG |= ADC_SYSclk_DIV_32;            // ADCЪБжгЦЕТЪSYSclk/16&0x0F;
  138   2              ADCCFG |= 1 << 5;                                           // зЊЛЛНсЙћгвЖдЦыЁЃ ADC_RES БЃДцНсЙћЕФИп 2 ЮЛЃЌ ADC_RESL БЃДцНсЙћЕФЕЭ 8
             - ЮЛЁЃ
  139   2              
  140   2              adc_resolution[0] = resolution;         // МЧТМADCОЋЖШ НЋдкВЩМЏЪБЪЙгУ
  141   2              
  142   2              ADC_CONTR |= 1 << 7;                                // ДђПЊ ADC ЕчдД
  143   2          }
  144   1          else if((ch >> 12) == 1)
  145   1          {
  146   2      
  147   2              ADC2_CONTR &= (0xF0);                           // ЧхГ§ADC_CHS[3:0] ЃК ADC ФЃФтЭЈЕРбЁдёЮЛ
  148   2              ADC2_CONTR |= (ch >> 8) & 0xF;
  149   2              
  150   2              ADC2CFG |= ADC_SYSclk_DIV_32;           // ADCЪБжгЦЕТЪSYSclk/16&0x0F;
  151   2              ADC2CFG |= 1 << 5;                                  // зЊЛЛНсЙћгвЖдЦыЁЃ ADC_RES БЃДцНсЙћЕФИп 2 ЮЛЃЌ ADC_RESL БЃДцНсЙ
             -ћЕФЕЭ 8 ЮЛЁЃ
  152   2              
  153   2              adc_resolution[1] = resolution;         // МЧТМADCОЋЖШ НЋдкВЩМЏЪБЪЙгУ
  154   2      
  155   2              ADC2_CONTR |= 1 << 7;                               // ДђПЊ ADC ЕчдД
  156   2          }
  157   1          system_delay_ms(1);
  158   1      }


