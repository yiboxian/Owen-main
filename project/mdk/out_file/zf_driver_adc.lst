   68          //-------------------------------------------------------------------------------------------------------
             -------------
   69          //  @brief      ADCзЊЛЛвЛДЮ
   70          //  @param      adcn            бЁдёADCЭЈЕР
   71          //  @param      resolution      ЗжБцТЪ
