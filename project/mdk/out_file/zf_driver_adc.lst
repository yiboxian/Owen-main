   73          //  Sample usage:               adc_convert(ADC1_CH0_P10);
   74          //-------------------------------------------------------------------------------------------------------
             -------------
   75          uint16 adc_convert(adc_channel_enum ch)
   76          {
   77   1          uint16 adc_value = 0;
   78   1          
   79   1          if((ch >> 12 )== 0)
   80   1          {
   81   2              ADC_CONTR &= ~0x20;                         // ЧхЭъГЩБъжО
   82   2              ADC_CONTR &= (0xF0);                        // ЧхГ§ADC_CHS[3:0] ЃК ADC ФЃФтЭЈЕРбЁдёЮЛ
   83   2              ADC_CONTR |= (ch >> 8) & 0xF;   
   84   2                  
   85   2              ADC_CONTR |= 0x40;                          // ЦєЖЏ AD зЊЛЛ
   86   2                  
   87   2              while (!(ADC_CONTR & 0x20));        // ВщбЏ ADC ЭъГЩБъжО
   88   2                  
   89   2              adc_value = ADC_RES << 8;                       // ДцДЂ ADC ЕФ 12 ЮЛНсЙћЕФИп 4 ЮЛ
   90   2              adc_value |= ADC_RESL;                      // ДцДЂ ADC ЕФ 12 ЮЛНсЙћЕФЕЭ 8 ЮЛ
   91   2              
   92   2              ADC_RES = 0;
   93   2              ADC_RESL = 0;
   94   2              
   95   2              adc_value >>= adc_resolution[0];        // ШЁЖрЩйЮЛ
   96   2          }
   97   1          else if((ch >> 12) == 1)
   98   1          {
   99   2              ADC2_CONTR &= ~0x20;                        // ЧхЭъГЩБъжО
  100   2              ADC2_CONTR &= (0xF0);                       // ЧхГ§ADC_CHS[3:0] ЃК ADC ФЃФтЭЈЕРбЁдёЮЛ
  101   2              ADC2_CONTR |= (ch >> 8) & 0xF;  
  102   2                  
  103   2              ADC2_CONTR |= 0x40;                         // ЦєЖЏ AD зЊЛЛ
  104   2                  
  105   2              while (!(ADC2_CONTR & 0x20));       // ВщбЏ ADC ЭъГЩБъжО
  106   2                  
  107   2              adc_value = ADC2_RES << 8;              // ДцДЂ ADC ЕФ 12 ЮЛНсЙћЕФИп 4 ЮЛ
  108   2              adc_value |= ADC2_RESL;                     // ДцДЂ ADC ЕФ 12 ЮЛНсЙћЕФЕЭ 8 ЮЛ
  109   2              
  110   2              ADC2_RES = 0;
  111   2              ADC2_RESL = 0;
  112   2              
  113   2              adc_value >>= adc_resolution[1];        //ШЁЖрЩйЮЛ
  114   2          
  115   2          }
  116   1          
C251 COMPILER V5.60.0,  zf_driver_adc                                                      13/01/26  21:31:31  PAGE 3   

  117   1          return adc_value;
  118   1      }
