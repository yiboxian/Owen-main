   53   1          uint8 i;
   54   1          uint32 sum;
   55   1      
   56   1              zf_assert(count);//ЖЯбдДЮЪ§ВЛФмЮЊ0
   57   1              
   58   1          sum = 0;
   59   1          for(i=0; i<count; i++)
   60   1          {
   61   2              sum += adc_convert(ch);
