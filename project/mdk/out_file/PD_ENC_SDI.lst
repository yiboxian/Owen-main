   87          void initSlidingAverage(SlidingAverageFilter* filter, int N) {
   88   1               uint8 Win_i=0;
   89   1          if (N > MAX_WINDOW_SIZE) {
   90   2              N = MAX_WINDOW_SIZE; // 限制窗口大小不能超过最大值
   91   2          }
   92   1      
   93   1          for (Win_i = 0; Win_i < MAX_WINDOW_SIZE; Win_i++) {
   94   2              filter->buffer[Win_i] = 0.0f;
   95   2          }
   96   1          filter->sum = 0.0f;
   97   1          filter->index = 0;
   98   1          filter->count = 0;
   99   1          filter->window_size = N;
  100   1      }
  101          
  102          void slidingAverage(float now_speed, float* avg_speed, SlidingAverageFilter* filter) {
  103   1          // 从和中减去即将被替换的旧值
  104   1          filter->sum -= filter->buffer[filter->index];
  105   1      
  106   1          // 将新的值插入缓冲区
  107   1          filter->buffer[filter->index] = now_speed;
  108   1      
  109   1          // 更新和
  110   1          filter->sum += now_speed;
  111   1      
  112   1          // 更新索引，使其循环回到起始位置
  113   1          filter->index = (filter->index + 1) % filter->window_size;
  114   1      
  115   1          // 如果窗口没有满，增加计数
  116   1          if (filter->count < filter->window_size) {
  117   2              filter->count++;
  118   2          }
  119   1      
  120   1          // 计算并返回当前窗口的平均值
  121   1          *avg_speed = filter->sum / filter->count;
