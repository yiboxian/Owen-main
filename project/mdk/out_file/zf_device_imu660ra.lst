                       }
                       
                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      Ҫ«valРҙИлcmd¶ФУҰөДјДҙжЖчөШЦ·,Н¬Кұ·ө»ШstatusЧЦҪЪ
                       //  @param      cmd         ГьБоЧЦ
                       //  @param      val         ҙэРҙИлјДҙжЖчөДКэЦө
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static void imu660ra_simspi_w_reg_byte(uint8 cmd, uint8 val)
                       {
                               cmd |= IMU660RA_SPI_W;
                               imu660ra_simspi_wr_byte(cmd);
                               imu660ra_simspi_wr_byte(val);
                       }
               
               
                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      Ҫ«valРҙИлcmd¶ФУҰөДјДҙжЖчөШЦ·
                       //  @param      cmd         ГьБоЧЦ
                       //  @param      val         ҙэРҙИлјДҙжЖчөДКэЦө
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static void imu660ra_simspi_w_reg_bytes(uint8 cmd, uint8 *dat_addr, uint32 len)
                       {
                               cmd |= IMU660RA_SPI_W;
                               imu660ra_simspi_wr_byte(cmd);
                               while(len--)
                               {
                                       imu660ra_simspi_wr_byte(*dat_addr++);
                               }
                       }
               
                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      ¶БИЎcmdЛщ¶ФУҰөДјДҙжЖчөШЦ·
                       //  @param      cmd         ГьБоЧЦ
                       //  @param      *val        ҙжҙў¶БИЎөДКэҫЭөШЦ·
                       //  @param      num         ¶БИЎөДКэБҝ
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static void imu660ra_simspi_r_reg_bytes(uint8 cmd, uint8 *val, uint32 num)
                       {
                               cmd |= IMU660RA_SPI_R;
                               imu660ra_simspi_wr_byte(cmd);
                               while(num--)
                               {
                                       *val++ = imu660ra_simspi_wr_byte(0);
                               }
                       }
               
               
