                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      НЁ№эSPIРҙТ»ёцbyte,Н¬Кұ¶БИЎТ»ёцbyte
                       //  @param      byte        ·ўЛНөДКэҫЭ
                       //  @return     uint8 edata       return ·ө»ШstatusЧҙМ¬
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static uint8 imu660ra_simspi_wr_byte(uint8 byte)
                       {
                               uint8 i;
                               for(i=0; i<8; i++)
                               {
                                       IMU660RA_SCK (0);
                                       IMU660RA_MOSI(byte&0x80);
                                       byte <<= 1;
                                       IMU660RA_SCK (1);
                                       byte |= IMU660RA_MISO;
                               }
                               IMU660RA_SCK (0);
C251 COMPILER V5.60.0,  zf_device_imu660ra                                                 21/03/26  13:02:32  PAGE 4   

