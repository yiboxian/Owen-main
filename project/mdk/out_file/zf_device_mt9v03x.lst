   72          // 函数简介     单独设置摄像头曝光时间
   73          // 参数说明     light           设定曝光时间
   74          // 返回参数     uint8           1-失败 0-成功
   75          // 使用示例     mt9v03x_set_exposure_time(100);                 // 调用该函数前请先初始化串口
   76          // 备注信息     设置曝光时间越大图像越亮
   77          //              摄像头收到后会根据分辨率及FPS计算最大曝光时间如果设置的数据过大
   78          //              那么摄像头将会设置这个最大值
   79          //-------------------------------------------------------------------------------------------------------
             -------------
   80          uint8 mt9v03x_set_exposure_time (uint16 light)
   81          {
   82   1          uint8 return_state = mt9v03x_sccb_set_exposure_time(light);
   83   1          return return_state;
   84   1      }
