   81   3                              case UART5_DMA_IRQn: DMA_UR5R_CFG &= ~(3<<2); DMA_UR5R_CFG |= priority << 2;break;
   82   3                              case UART6_DMA_IRQn: DMA_UR6R_CFG &= ~(3<<2); DMA_UR6R_CFG |= priority << 2;break;
   83   3                              case UART7_DMA_IRQn: DMA_UR7R_CFG &= ~(3<<2); DMA_UR7R_CFG |= priority << 2;break;
   84   3                              case UART8_DMA_IRQn: DMA_UR8R_CFG &= ~(3<<2); DMA_UR8R_CFG |= priority << 2;break;
   85   3      
   86   3                              case LCM_DMA_IRQn:DMA_LCM_CFG &= ~(3<<2); DMA_LCM_CFG |= priority << 2;break;
