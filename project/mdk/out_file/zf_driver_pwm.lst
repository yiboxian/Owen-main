  248          void pwm_init(pwm_channel_enum pin, uint32 freq, uint32 duty)
  249          {
  250   1      
  251   1          uint16 match_temp = 0;                                              // еМПеБШжЕ
  252   1          uint32 period_temp = 0;                                             // жмЦкжЕ
  253   1          uint16 freq_div = 0;                                                // ЗжЦЕжЕ
  254   1          
