  256   1          zf_assert(PWM_DUTY_MAX >= duty);
  257   1              
  258   1          gpio_init(pin  & 0xFF, GPO, 1, GPO_PUSH_PULL);                                              // GPIOашвЊЩшжУЮЊЭЦЭьЪфГі
  259   1      
  260   1          //ЗжЦЕМЦЫуЃЌжмЦкМЦЫуЃЌеМПеБШМЦЫу
  261   1          freq_div = (system_clock / freq) >> 16;                                                             // ЗжЦЕжЕ
  262   1          period_temp = system_clock / freq;
  263   1          period_temp = period_temp / (freq_div + 1) - 1;                                             // жмЦкжЕ
  264   1              
  265   1          if(duty != PWM_DUTY_MAX)
  266   1          {           
  267   2              match_temp = period_temp * ((float)duty / PWM_DUTY_MAX);                // еМПеБШ
  268   2          }
  269   1          else
  270   1          {
  271   2              match_temp = period_temp + 1;                                                                   // dutyЮЊ100%
  272   2          }
