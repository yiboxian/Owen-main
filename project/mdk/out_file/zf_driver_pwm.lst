  277   1              
  278   1              PWMX_ARRH(pin) = (uint8)(period_temp >> 8);             // жмЦкжЕ Ип8ЮЛ
  279   1              PWMX_ARRL(pin) = (uint8)period_temp;                    // жмЦкжЕ ЕЭ8ЮЛ
  280   1      
  281   1          PWMX_CCRXH(pin) = (uint8)(match_temp >> 8);         // БШНЯжЕ Ип8ЮЛ
