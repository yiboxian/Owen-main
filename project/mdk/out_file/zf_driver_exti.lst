   39          //  @brief      外部中断初始化
   40          //  @param      NULL                    
   41          //  @return     void
   42          //  Sample usage:               exit_init(INT0_P32,BOTH) //初始化P32 作为外部中断引脚，双边沿触发。
   43          //-------------------------------------------------------------------------------------------------------
             -------------
   44          void exit_init(INTN_enum int_n,INT_MODE_enum mode)
   45          {
   46   1              if(INT0_P32 == int_n)
   47   1              {
   48   2                      IT0 = mode;
   49   2                      EX0 = 1;                    //使能INT0中断
   50   2              }
   51   1      
   52   1              if(INT1_P33 == int_n)
C251 COMPILER V5.60.0,  zf_driver_exti                                                     13/01/26  21:31:31  PAGE 2   

   53   1              {
   54   2                      IT1 = mode;
   55   2                      EX1 = 1;                    //使能INT1中断
   56   2              }
   57   1              
   58   1              if(INT2_P36 == int_n)
   59   1              {
   60   2                      INTCLKO |= 1<<4;        //使能INT2中断
   61   2              }
   62   1              
   63   1              if(INT3_P37 == int_n)
   64   1              {
   65   2                      INTCLKO |= 1<<5;        //使能INT3中断
   66   2              }
   67   1              
