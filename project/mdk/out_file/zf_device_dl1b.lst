  115   4                      {
  116   5                          dl1b_distance_mm = dl1b_distance_temp;
  117   5                          dl1b_finsh_flag = 1;
  118   5                      }
  119   4                  }
  120   3                  else
  121   3                  {
  122   4                      dl1b_distance_mm = 8192;
  123   4                      dl1b_finsh_flag = 0;
  124   4                  }
  125   3              }
  126   2              else
