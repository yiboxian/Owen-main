   52          
C251 COMPILER V5.60.0,  zf_driver_delay                                                    13/01/26  21:31:31  PAGE 2   

   53          //-------------------------------------------------------------------------------------------------------
             -------------
   54          // 函数简介     系统延时，使用定时器11
   55          // 参数说明     period              设置的值
   56          // 返回参数     void
   57          // 使用示例     内部使用，用户无需关心
   58          //-------------------------------------------------------------------------------------------------------
             -------------
   59          void system_delay(uint32 period)
   60          {
   61   1          uint8 freq_div;                
   62   1          uint16 period_temp;               
   63   1          uint16 temp;
   64   1      
   65   1          T11CR = 0;
   66   1          if(period > (255 * 65535))
   67   1          {
   68   2              // 设置定时器为12T模式防止溢出
   69   2              period = (period + 5) / 12;  // 四舍五入，降低整数除法误差
   70   2              T11CR &= ~0x10;
   71   2          }
   72   1          else
   73   1          {
   74   2              // 设置为1T模式
   75   2              T11CR |= 0x10;
   76   2          }
   77   1          
   78   1          freq_div = ((period) >> 16);                    // 计算预分频
   79   1          period_temp = ((period) / (freq_div + 1));      // 计算自动重装载值
   80   1          temp = (uint16)65535 - period_temp;
   81   1      
   82   1          T11PS = freq_div;                               // 设置分频值
   83   1          T11L = temp;
   84   1          T11H = temp >> 8;
   85   1          T11CR |= 0x80;                                      // 启动定时器
   86   1          
   87   1          while(!(T11CR & 0x01));                         // 等待硬件定时器溢出
   88   1      
   89   1      }


