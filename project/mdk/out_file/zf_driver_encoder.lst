  208   1          gpio_init(ch2_pin  & 0xFF, GPI, 1, GPI_IMPEDANCE);              // 初始化引脚
  209   1      
  210   1          PWMX_PS(ch1_pin)  |= ((ch1_pin >> 8) & 0x03) << (((ch1_pin >> 11) & 0x03) * 2);                             // 选择引脚
  211   1          PWMX_PS(ch2_pin)  |= ((ch2_pin >> 8) & 0x03) << (((ch2_pin >> 11) & 0x03) * 2);                             // 选择引脚
