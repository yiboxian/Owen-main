   71   3                  case TIM7_ENCODER: ret = (uint16)T7H << 8; ret |= T7L; break;
   72   3                  case TIM8_ENCODER: ret = (uint16)T8H << 8; ret |= T8L; break;
   73   3                  case TIM9_ENCODER: ret = (uint16)T9H << 8; ret |= T9L; break;
