   38          void DMA_UART1_IRQHandler(void) interrupt DMA_UR1R_VECTOR
   39          {
   40   1          static vuint8 dwon_count = 0;
   41   1      
   42   1          if (DMA_UR1R_STA & 0x01) // 接收完成
   43   1          {
   44   2              DMA_UR1R_STA &= ~0x01;      // 清标志位
   45   2              uart_rx_start_buff(UART_1); // 设置下一次接收，务必保留
   46   2      
   47   2              // 程序自动下载
   48   2              if (uart_rx_buff[UART_1][0] == 0x7F)
   49   2              {
   50   3                  if (dwon_count++ > 20)
   51   3                  {
   52   4                      IAP_CONTR = 0x60;
   53   4                  }
   54   3              }
