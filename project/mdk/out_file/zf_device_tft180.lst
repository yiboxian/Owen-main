  499          void tft180_show_gray_image (uint16 x, uint16 y, const uint8 *image, uint16 width, uint16 height, uint16 
             -dis_width, uint16 dis_height, uint8 threshold)
  500          {
  501   1          uint32 i = 0, j = 0;
  502   1          uint16 color,temp;
  503   1          uint32 width_index, height_index;
  504   1      
  505   1          // Из№ыіМРтФЪКдіцБЛ¶ПСФРЕПў ІўЗТМбКѕіцґнО»ЦГФЪХвАп
  506   1          // ДЗГґТ»°гКЗЖБД»ПФКѕµДК±єті¬№эЖБД»·Ц±жВК·¶О§БЛ
  507   1          zf_assert(x < tft180_x_max);
  508   1          zf_assert(y < tft180_y_max);
  509   1          zf_assert(NULL != image);
  510   1      
  511   1          TFT180_CS(0);
  512   1          tft180_set_region(x, y, x + dis_width - 1, y + dis_height - 1);             // ЙиЦГПФКѕЗшУт
  513   1      
  514   1          for(j = 0; j < dis_height; j ++)
  515   1          {
  516   2              height_index = j * height / dis_height;
  517   2              for(i = 0; i < dis_width; i ++)
  518   2              {
  519   3                  width_index = i * width / dis_width;
  520   3                  temp = *(image + height_index * width + width_index);               // ¶БИЎПсЛШµг
  521   3                  if(threshold == 0)
  522   3                  {
  523   4                      color = (0x001f & ((temp) >> 3)) << 11;
  524   4                      color = color | (((0x003f) & ((temp) >> 2)) << 5);
  525   4                      color = color | (0x001f & ((temp) >> 3));
  526   4                      tft180_write_16bit_data(color);
  527   4                  }
  528   3                  else if(temp < threshold)
  529   3                  {
  530   4                      tft180_write_16bit_data(RGB565_BLACK);
  531   4                  }
  532   3                  else
  533   3                  {
  534   4                      tft180_write_16bit_data(RGB565_WHITE);
  535   4                  }
  536   3              }
  537   2          }
  538   1          TFT180_CS(1);
  539   1      }
