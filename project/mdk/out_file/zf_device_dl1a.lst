  543   2              {
C251 COMPILER V5.60.0,  zf_device_dl1a                                                     13/01/26  21:31:34  PAGE 10  

  544   3                  // 假设线性度校正增益为默认值 1000 且未启用分数范围
  545   3                  dl1a_read_registers(DL1A_RESULT_RANGE_STATUS + 10, reg_databuffer, 2);
