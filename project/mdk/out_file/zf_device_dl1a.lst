  554   2              {
  555   3                  dl1a_read_registers(DL1A_RESULT_RANGE_STATUS + 10, reg_databuffer, 2);
  556   3                  dl1a_write_register(DL1A_SYSTEM_INTERRUPT_CLEAR, 0x01);
  557   3              }
  558   2          }
  559   1      }
