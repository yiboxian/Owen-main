  197          static uint16 dl1a_decode_timeout (uint16 reg_val)
  198          {
  199   1          // 格式: (LSByte * 2 ^ MSByte) + 1
  200   1          return  (uint16)((reg_val & 0x00FF) <<
  201   1                           (uint16)((reg_val & 0xFF00) >> 8)) + 1;
  202   1      }
