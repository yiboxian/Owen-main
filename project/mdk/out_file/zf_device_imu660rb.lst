                       static void imu660rb_simspi_w_reg_byte(uint8 cmd, uint8 val)
                       {
                               cmd |= IMU660RB_SPI_W;
                               imu660rb_simspi_wr_byte(cmd);
                               imu660rb_simspi_wr_byte(val);
                       }
               
