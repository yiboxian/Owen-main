                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      ЭЈЙ§SPIаДвЛИіbyte,ЭЌЪБЖСШЁвЛИіbyte
                       //  @param      byte        ЗЂЫЭЕФЪ§Он
                       //  @return     uint8 edata       return ЗЕЛиstatusзДЬЌ
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static uint8 imu660rb_simspi_wr_byte(uint8 byte)
                       {
                               uint8 i;
                               for(i=0; i<8; i++)
                               {
                                       IMU660RB_SCK (0);
                                       IMU660RB_MOSI(byte&0x80);
                                       byte <<= 1;
                                       IMU660RB_SCK (1);
                                       byte |= IMU660RB_MISO;
                               }
                               IMU660RB_SCK (0);
                               return(byte);
                       }
                       
