             -------------
  244          // 函数简介     串口开始接收数据
  245          // 参数说明     uart_n       串口通道
  246          // 返回参数     void
  247          // 使用示例     uart_rx_start_buff(UART_1);
  248          //-------------------------------------------------------------------------------------------------------
             -------------
  249          void uart_rx_start_buff(uart_index_enum uart_n)
  250          {
  251   1          DMA_URXR_AMT(uart_n) = (1 - 1);                                                                             // 设置接收的字节数
  252   1          DMA_URXR_AMTH(uart_n) = (1 - 1) >> 8;                                                               // 设置接收的字节数
  253   1          DMA_URXR_RXAL(uart_n) = (uint8)((uint16)uart_rx_buff[uart_n]);              // 设置接收缓冲地址
  254   1          DMA_URXR_RXAH(uart_n) = (uint8)((uint16)uart_rx_buff[uart_n] >> 8); // 设置接收缓冲地址
  255   1          DMA_URXR_CR(uart_n) = 0xA1;                                                                                 // 开启DMA RX接收中断，开启DMA RX接收，清空FIFO
  256   1      }
