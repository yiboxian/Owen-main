  259          // 函数简介     打开串口接收中断
  260          // 参数说明     uart_n       串口通道
  261          // 参数说明     status      使能或者失能
  262          // 返回参数     void
  263          // 使用示例     uart_rx_irq(UART_1, ENABLE);        //打开串口1接收中断
  264          //-------------------------------------------------------------------------------------------------------
             -------------
  265          void uart_rx_interrupt (uart_index_enum uart_n, uint8 status, uart_callback_function callback_handler)
  266          {
  267   1              if(status)
  268   1              {
  269   2                      DMA_URXR_CFG(uart_n) |= 0x80;
  270   2              }
  271   1              else
  272   1              {
  273   2                      DMA_URXR_CFG(uart_n) &= ~0x80;
  274   2              }
  275   1          // 设置回调函数
  276   1          uart_rx_handlers[uart_n] = callback_handler;
  277   1      }
