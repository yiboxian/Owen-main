  182          //-------------------------------------------------------------------------------------------------------
             -------------
  183          // 函数简介     串口发送数组
  184          // 参数说明     uart_n       串口通道
  185          // 参数说明     buff        要发送的数组地址
  186          // 参数说明     len         数据长度
  187          // 返回参数     void
  188          // 使用示例     uart_write_buffer(UART_1, buff, 10);     //串口1发送10个buff数组。
  189          //-------------------------------------------------------------------------------------------------------
             -------------
  190          void uart_write_buffer(uart_index_enum uart_n, const uint8 *buff, uint16 len)
  191          {
  192   1          #define BUFF_LEN 64
  193   1              
  194   1              // 因UART_DMA只能操作xdata区域的数据，所以，这里新建一个数组，搬移。
  195   1              uint8 xdata tmp_buff[BUFF_LEN] = {0};
  196   1          uint16 tmp_len = 0;
  197   1              while(len)
  198   1              {
  199   2              tmp_len = (len > BUFF_LEN) ? BUFF_LEN : len;        // 计算长度
  200   2              memcpy(tmp_buff, buff, tmp_len);                    // 拷贝
  201   2              len -= tmp_len;                                     // 去掉已经发送的长度
  202   2              buff += tmp_len;                                    // 指针指向后面
  203   2              
  204   2              DMA_URXT_CFG(uart_n)  = 0x00;                           // DMA优先级低
  205   2              DMA_URXT_STA(uart_n)  = 0;                                          // 清空标志位
  206   2      
  207   2              DMA_URXT_AMT(uart_n)  = (tmp_len - 1) & 0xff;           // 设置传输总字节数(低8位)：n+1
  208   2              DMA_URXT_AMTH(uart_n) = (tmp_len - 1) >> 8;                 // 设置传输总字节数(高8位)：n+1
  209   2              DMA_URXT_TXAH(uart_n) = (uint8)((uint16)tmp_buff >> 8);
  210   2              DMA_URXT_TXAL(uart_n) = (uint8)((uint16)tmp_buff);
  211   2              DMA_URXT_CR(uart_n) = 0xC0;                                 // 使能DMA TX功能
  212   2      
  213   2              while(!(DMA_URXT_STA(uart_n) & 0x01));              // 等待发送完成
  214   2      
  215   2              DMA_URXT_CR(uart_n) = 0x00;                                         // 关闭DMA TX
  216   2              }
  217   1      }
  218          //-------------------------------------------------------------------------------------------------------
             -------------
  219          // 函数简介     串口发送字符串
  220          // 参数说明     uart_n       串口通道
  221          // 参数说明     str         字符串首地址
  222          // 返回参数     void
  223          // 使用示例     uart_putstr(UART_1, (uint8 *)"12345")   //串口1发送12345这个字符串
  224          //-------------------------------------------------------------------------------------------------------
             -------------
  225          void uart_write_string(uart_index_enum uart_n, const char *str)
  226          {
  227   1          uint16 len = strlen(str);
  228   1          uart_write_buffer(uart_n, str, len);
