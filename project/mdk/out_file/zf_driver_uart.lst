  309          // 使用示例     uint8 dat; uart_query_byte(USART_1,&dat);       // 接收串口1数据  存在在dat变量里
  310          //-------------------------------------------------------------------------------------------------------
             -------------
  311          uint8 uart_query_byte(uart_index_enum uart_n, uint8 *dat)
  312          {
  313   1              uint8 ret = 0; 
  314   1      
  315   1              // 读取数据
  316   1              *dat = uart_rx_buff[uart_n][0];
  317   1              
  318   1              if(DMA_URXR_STA(uart_n) & 0x03)
  319   1              {
  320   2                      ret = 1;
  321   2                      
  322   2                      DMA_URXR_STA(uart_n) &= ~0x03;
  323   2              }
  324   1              else
  325   1              {
  326   2                      ret = 0;
  327   2              }
  328   1              
  329   1              // 开始下一次接收
  330   1              uart_rx_start_buff(uart_n);
  331   1      
  332   1              return ret;
  333   1      }
