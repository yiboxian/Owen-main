  286          uint8 uart_read_byte(uart_index_enum uart_n)
C251 COMPILER V5.60.0,  zf_driver_uart                                                     13/01/26  21:31:32  PAGE 6   

  287          {
  288   1              uint8 dat;
  289   1              
  290   1              // 等待串口有数据
  291   1              while(!(DMA_URXR_STA(uart_n)&0x03));
  292   1      
  293   1              // 读取数据
  294   1              dat = uart_rx_buff[uart_n][0];
  295   1                      
  296   1              // 清空标志位
  297   1              DMA_URXR_STA(uart_n) = 0x00;
  298   1              
  299   1              // 开始下一次接收
  300   1              uart_rx_start_buff(uart_n);
  301   1              return dat;
  302   1      }
