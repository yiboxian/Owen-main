  237          //-------------------------------------------------------------------------------------------------------
             -------------
  238          void uart_write_byte(uart_index_enum uart_n, const uint8 dat)
  239          {
  240   1          uart_write_buffer(uart_n, &dat, 1);
  241   1      }
