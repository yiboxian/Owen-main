  743   2                      case SPI_1:                 
  744   2                  SPSTAT = 0xc0;              
  745   2                              SPDAT = dat;                            
  746   2                              while (!(SPSTAT & 0x80));  
  747   2                              break;                  
  748   2                      case SPI_2:
  749   2                  SPI2STAT = 0xc0;              
  750   2                              SPI2DAT = dat;                          
  751   2                              while (!(SPI2STAT & 0x80));
  752   2                              break;     
  753   2              case SPI_3:
  754   2                  SPI3STAT = 0xc0;              
  755   2                              SPI3DAT = dat;                          
  756   2                              while (!(SPI3STAT & 0x80));  
  757   2                              break;           
  758   2                      default:                    
  759   2                              zf_assert(0);           
  760   2                              break;                  
  761   2              }
  762   1      }
