  304   1          
  305   1          // ЕШД§ЭЈбЖГЩЙІ
  306   1          while(0 == (0x80 & imu963ra_read_acc_gyro_register(IMU963RA_STATUS_MASTER)))
  307   1          {
  308   2              if(IMU963RA_TIMEOUT_COUNT < timeout_count ++)
  309   2              {
  310   3                  return_state = 1;
  311   3                  break;
  312   3              }
  313   2              
  314   2              system_delay_ms(2);
  315   2          }
  316   1          
  317   1          return return_state;
  318   1      }
