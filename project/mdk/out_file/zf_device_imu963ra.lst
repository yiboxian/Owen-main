                       static void imu963ra_simspi_r_reg_byte(uint8 cmd, uint8 *val)
                       {
                               IMU963RA_CS(0);
                               cmd |= IMU963RA_SPI_R;
                               imu963ra_simspi_wr_byte(cmd);
                               *val = imu963ra_simspi_wr_byte(0);
                               IMU963RA_CS(1);
                       }
               
                       //------------------------------------------------------------------------------------------------------
             --------------
                       //  @brief      ЖСШЁcmdЫљЖдгІЕФМФДцЦїЕижЗ
                       //  @param      cmd         УќСюзж
                       //  @param      *val        ДцДЂЖСШЁЕФЪ§ОнЕижЗ
                       //  @param      num         ЖСШЁЕФЪ§СП
                       //  @since      v1.0
                       //  Sample usage:
                       //------------------------------------------------------------------------------------------------------
             --------------
                       static void imu963ra_simspi_r_reg_bytes(uint8 cmd, uint8 *val, uint32 num)
                       {
                               cmd |= IMU963RA_SPI_R;
                               imu963ra_simspi_wr_byte(cmd);
                               while(num--)
                               {
                                       *val++ = imu963ra_simspi_wr_byte(0);
                               }
                       }
               
