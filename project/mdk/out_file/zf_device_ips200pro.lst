  209          #if(1 == IPS200PRO_CRC_ENABLE)
               static uint8 ips200pro_calculate_crc8(uint8 *dat, uint32 length)
               {
                   uint8 i, crc = 0;
                   while(length--)
                   {
                       crc ^= *dat++;
                       for (i = 0; i < 8; i++)
                       {
                           crc = (crc & 0x80) ? ((crc << 1) ^ 0x07) : (crc <<= 1);
                       }
                   }
                   return crc;
               }
               #endif
