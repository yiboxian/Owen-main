   47          
   48          
   49          void clock_init (uint32 clock)                                              // 核心时钟初始化
   50          {
   51   1          uint8 pll_div = ((clock / 1000000UL - 78) / 3);
   52   1          interrupt_global_disable();
   53   1          EAXFR = 1;                              // 使能访问XFR
   54   1              // CKCON = 0;
C251 COMPILER V5.60.0,  zf_common_clock                                                    13/01/26  21:31:30  PAGE 2   

   55   1          if((120*1000*1000UL) <= clock)
   56   1          {
   57   2              WTST = 4;
   58   2          }
   59   1          else if((80*1000*1000UL) <= clock)
   60   1          {
   61   2              WTST = 3;
   62   2          }
   63   1          else if((80*1000*1000UL) <= clock)
   64   1          {
   65   2              WTST = 2;
   66   2          }
   67   1          else
   68   1          {
   69   2              WTST = 4;
   70   2          }
   71   1      
   72   1      #if(INTERNAL_CRYSTAL == USER_CRTSTAL)
   73   1          CLKDIV = 2;                 // 设置系统时钟=xxxMhz/2/2=clock，（因为CLKSEL选择时，已经将HPLL/2了）
   74   1      
   75   1              //以下为超过60MHz时，系统时钟使用HPLL方式提供
   76   1              VRTRIM = CHIPID22;                  // 载入27MHz频段的VRTRIM值
   77   1              IRTRIM = CHIPID12;                  // 指定当前HIRC为24MHz，此时会覆盖掉ISP设置的时钟频率
   78   1              IRCBAND &= ~0x03;                       // 清空频段选择
   79   1              IRCBAND |= 0x01;                        // 选择27Mhz频段
   80   1              HPLLCR &= ~0x10;            // 选择HPLL输入时钟源为HIRC
   81   1              HPLLPDIV = 4;                           // 24MHz/4=6MHz,需要保证输入HPLL的时钟在6MHz附近
   82   1          HPLLCR |= pll_div & 0x0F;   // 设置PLL1倍频系数
   83   1              HPLLCR |= 0x80;             // 使能HPLL
   84   1          soft_delay(50000);
   85   1              CLKSEL &= ~0x03;                        // BASE_CLK选择为HIRC，用以提供给HPLL
   86   1              CLKSEL &= ~0x0c;                        // 清空主时钟源选择
   87   1              CLKSEL |= 1<<2;                         // 设置主时钟源为内部 HPLL1 输出/2
   88   1         
   89   1      #elif(EXTERNAL_CRYSTAL == USER_CRTSTAL)
               
                   CLKDIV = 2;                 // 设置系统时钟=xxxMhz/2/2=clock，（因为CLKSEL选择时，已经将HPLL/2了）
               
                   CLKSEL &= ~0x03;                    //BASE_CLK选择为HIRC，用以提供给HPLL
                       CLKSEL &= ~0x0c;                        //清空主时钟源选择
               
                   XOSCCR = 3<<6 | 1 << 2 | 1<<5;    // 选择外部晶振,24M晶振
                   soft_delay(50000);
                   while (!(XOSCCR & 1));      // 等待时钟稳定
               
                   HPLLCR &= ~(1<<4);          // 内部基本时钟(BASECLK)
                   HPLLPDIV = 4;               // 必须为6M，这里24M晶振4分频
                   HPLLCR |= pll_div & 0x0F; // 设置PLL1倍频系数
               
               //    HPLL2CR |= 6;            // 设置PLL2倍频系数
                   HPLLCR |= 0<<5;            // PLL1/2提供给两组高速I2S时钟
               //    HPLL2CR |= 0<<5;            // PLL1/2提供给两组高速外设时钟
                   HPLLCR |= 1<<7;            // 使能HPLL
               
                   // 先设置好时钟，最后切换外部高速晶振
                   CLKSEL = 1 << 0 | 1 << 2;   // 选择外部高速晶振, 内部HPLL1输出/2
               
               #endif
  113   1      
  114   1      
  115   1          ADCCFG = 0;
  116   1          AUXR = 0;
  117   1          SCON = 0;
  118   1          S2CON = 0;
  119   1          S3CON = 0;
  120   1          S4CON = 0;
C251 COMPILER V5.60.0,  zf_common_clock                                                    13/01/26  21:31:30  PAGE 3   

  121   1          P_SW1 = 0;
  122   1          IE2 = 0;
  123   1          TMOD = 0;
  124   1      
  125   1          system_clock = clock;
  126   1      
  127   1      #if(USER_USB_CDC)
  128   1          // 使能USB时钟，以及初始化USB相关引脚
  129   1          P3M0 &= ~0x03;
  130   1          P3M1 |= 0x03;
  131   1      
