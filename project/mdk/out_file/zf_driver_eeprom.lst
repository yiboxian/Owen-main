  208          void iap_erase_page(uint32 addr)
  209          {
  210   1              bit flag = 0;
  211   1      
  212   1              flag = EA;
  213   1              EA = 0;
  214   1          IAP_CMD = 3;                                //设置 IAP 擦除命令
  215   1          IAP_ADDRL = addr;                   //设置 IAP 低地址
  216   1          IAP_ADDRH = addr >> 8;      //设置 IAP 高地址
  217   1          IAP_ADDRE = addr >> 16;             //设置 IAP 最高地址
  218   1          eeprom_trig();
  219   1          
  220   1              EA = flag;
  221   1          system_delay_ms(10);                //擦除1扇区(512字节)：约4-6ms
  222   1      }
