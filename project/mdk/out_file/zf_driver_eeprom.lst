  120          uint8 iap_read_byte(uint32 addr)
  121          {
  122   1              uint8 temp;
  123   1              bit flag = 0;
  124   1              flag = EA;
  125   1              EA = 0;
  126   1              
  127   1          IAP_CMD = 1;                                //设置 IAP 读命令
  128   1      
  129   1              IAP_ADDRL = addr;               //设置 IAP 低地址
  130   1              IAP_ADDRH = addr >> 8;  //设置 IAP 高地址
  131   1              IAP_ADDRE = addr >> 16; //设置 IAP 最高地址
