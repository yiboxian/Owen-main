  190          //-------------------------------------------------------------------------------------------------------
             -------------
  191          void iap_write_buff(uint32 addr, uint8 *buf, uint16 len)
  192          {
  193   1              while(len--)
  194   1          {
  195   2              iap_write_byte(addr, *buf);             //读 IAP 数据
  196   2              addr++;
  197   2                      buf++;
  198   2          }
  199   1      }
