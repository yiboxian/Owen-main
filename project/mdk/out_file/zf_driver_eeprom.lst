  232          //                                                              将"0123456789"写入0x00-0x0A地址中;
  233          // 注意事项                                             不要跨扇区使用。
  234          //                                                              addr地址：0-511为一个扇区,512-1023为一个扇区，1024-1535为一个扇区，依次类推
  235          //-------------------------------------------------------------------------------------------------------
             -------------
  236          void extern_iap_write_buff(uint16 addr, uint8 *buf, uint16 len)
  237          {
  238   1          uint8 temp[512] = {0};
  239   1          uint16 i;
  240   1          
  241   1          for(i = 0; i < 512 ; i++)   temp[i] = 0;                                            //清0
  242   1          
  243   1          iap_read_buff(addr & 0xFE00, temp, 512);                                            //读取
  244   1          
  245   1          for(i = 0; i < len; i++)    temp[(addr & 0x1FF) + i] = buf[i];      //改
  246   1          
  247   1          iap_erase_page(addr);                                                                                       //擦除
  248   1          iap_write_buff(addr & 0xFE00, temp, 512);                                   //写入
  249   1      }
