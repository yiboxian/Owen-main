   48          void eeprom_trig(void)
   49          {
   50   1      
   51   1          IAP_TRIG = 0x5A;
   52   1          IAP_TRIG = 0xA5;                    //先送5AH，再送A5H到IAP触发寄存器，每次都需要如此
C251 COMPILER V5.60.0,  zf_driver_eeprom                                                   21/03/26  13:02:29  PAGE 2   

   53   1          //送完A5H后，IAP命令立即被触发启动
   54   1          //CPU等待IAP完成后，才会继续执行程序。
   55   1          _nop_();   //由于STC32G144K是多级流水线的指令系统，触发命令后建议加4个NOP，保证IAP_DATA的数据完成准备
   56   1          _nop_();
   57   1          _nop_();
   58   1          _nop_();
   59   1      
   60   1      }
