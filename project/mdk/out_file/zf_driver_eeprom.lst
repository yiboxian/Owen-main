  173          void iap_read_buff(uint32 addr, uint8 *buf, uint16 len)
  174          {
  175   1          while(len--)
  176   1          {
  177   2              *buf++ = iap_read_byte(addr);           //读 IAP 数据
  178   2              addr++;
  179   2          }
  180   1      }
