  644   1      
  645   1          ips200_write_index(0x36);
  646   1          system_delay_ms(100);
  647   1          if      (ips200_display_dir==0) ips200_write_8bit_data(0x00);
  648   1          else if (ips200_display_dir==1) ips200_write_8bit_data(0xC0);
  649   1          else if (ips200_display_dir==2) ips200_write_8bit_data(0x70);
  650   1          else                            ips200_write_8bit_data(0xA0);
  651   1      
  652   1          ips200_write_index(0x3A);
  653   1          ips200_write_8bit_data(0x05);
  654   1      
  655   1          ips200_write_index(0xB2);
  656   1          ips200_write_8bit_data(0x0C);
  657   1          ips200_write_8bit_data(0x0C);
