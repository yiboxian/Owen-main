  572          void ips200_show_gray_image (uint16 x, uint16 y, const uint8 *image, uint16 width, uint16 height, uint16 
             -dis_width, uint16 dis_height, uint8 threshold)
  573          {
  574   1          uint32 i = 0, j = 0;
  575   1          uint16 color ,temp ;
  576   1          uint16 data_buffer[IPS_WIGHT];
  577   1          const uint8 *image_temp;
  578   1      
  579   1          // ШчЙћГЬађдкЪфГіСЫЖЯбдаХЯЂ ВЂЧвЬсЪОГіДэЮЛжУдкетРя
  580   1          // ФЧУДвЛАуЪЧЦСФЛЯдЪОЕФЪБКђГЌЙ§ЦСФЛЗжБцТЪЗЖЮЇСЫ
  581   1          zf_assert(x < ips200_x_max);
  582   1          zf_assert(y < ips200_y_max);
  583   1          zf_assert(NULL != image);
  584   1      
  585   1          IPS200_CS(0);
  586   1      
  587   1          ips200_set_region(x, y, x + dis_width - 1, y + dis_height - 1);             // ЩшжУЯдЪОЧјгђ
  588   1      
  589   1          for(j = 0; j < dis_height; j ++)
  590   1          {
  591   2              image_temp = image + j * height / dis_height * width;                   // жБНгЖд image ВйзїЛс Ha
             -rdfault днЪБВЛжЊЕРЮЊЪВУД
  592   2              for(i = 0; i < dis_width; i ++)
  593   2              {
  594   3                  temp = *(image_temp + i * width / dis_width);                       // ЖСШЁЯёЫиЕу
  595   3                  if(threshold == 0)
  596   3                  {
  597   4                      color = (0x001f & ((temp) >> 3)) << 11;
  598   4                      color = color | (((0x003f) & ((temp) >> 2)) << 5);
  599   4                      color = color | (0x001f & ((temp) >> 3));
  600   4                      data_buffer[i] = (color);
  601   4                  }
  602   3                  else if(temp < threshold)
C251 COMPILER V5.60.0,  zf_device_ips200                                                   21/03/26  13:02:31  PAGE 11  

  603   3                  {
  604   4                      data_buffer[i] = (RGB565_BLACK);
  605   4                  }
  606   3                  else
  607   3                  {
  608   4                      data_buffer[i] = (RGB565_WHITE);
  609   4                  }
  610   3              }
  611   2              ips200_write_16bit_data_array(data_buffer, dis_width);
  612   2          }
  613   1      
  614   1              IPS200_CS(1);
  615   1      
  616   1      }
